<div class="animate-in slide-in-from-bottom-4">
    <!-- ZONA FIJA (STICKY) PARA EL TÍTULO Y EL BUSCADOR -->
    <div class="sticky top-0 z-30 bg-slate-50 dark:bg-slate-900 pt-4 pb-4 mb-6 border-b border-slate-200 dark:border-slate-700 shadow-sm -mt-4 -mx-4 px-4 sm:-mx-6 sm:px-6 md:-mx-10 md:px-10 transition-colors">
        <h2 class="text-2xl font-bold text-slate-800 dark:text-white mb-4 flex items-center gap-2 transition-colors">
            <i data-lucide="search" class="text-indigo-600 dark:text-indigo-400"></i> Consultas y Control de Entrada
        </h2>
        
        <!-- BUSCADOR UNIVERSAL EN VIVO RESTAURADO -->
        <div class="relative group">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none transition-colors group-focus-within:text-indigo-500">
                <i data-lucide="search" class="h-6 w-6 text-slate-400 group-focus-within:text-indigo-500 transition-colors"></i>
            </div>
            <input type="text" id="liveSearchInput" 
                   class="w-full pl-12 pr-12 py-4 bg-white dark:bg-slate-800 border-2 border-slate-200 dark:border-slate-700 rounded-xl text-slate-800 dark:text-white placeholder-slate-400 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/20 outline-none transition-all shadow-sm text-lg" 
                   placeholder="Busque por ticket, documento, nombre o apellidos..."
                   autocomplete="off">
            
            <button id="clearSearchBtn" class="hidden absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors focus:outline-none">
                <i data-lucide="x-circle" class="h-6 w-6"></i>
            </button>
        </div>
    </div>

    <!-- TABLA DE RESULTADOS -->
    <% if (typeof attendees !== 'undefined') { %>
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden transition-colors">
            <!-- TABLA CON SCROLL INTERNO PARA CABECERAS FIJAS -->
            <div class="overflow-auto w-full max-h-[65vh] relative">
                <table class="w-full text-left border-collapse min-w-[600px] relative">
                    <thead class="sticky top-0 z-20 shadow-sm">
                        <tr class="bg-slate-100 dark:bg-slate-900 text-slate-600 dark:text-slate-300 text-sm border-b border-slate-200 dark:border-slate-700 transition-colors">
                            <th class="p-4 font-semibold whitespace-nowrap">Ticket y Doc</th>
                            <th class="p-4 font-semibold whitespace-nowrap">Nombres e Iglesia</th>
                            
                            <th class="p-4 font-semibold whitespace-nowrap">
                                <% const nextSort = (typeof sortOrder !== 'undefined' && sortOrder === 'asc') ? 'desc' : 'asc'; %>
                                <a href="/consult?sort=<%= nextSort %>" 
                                   class="inline-flex items-center gap-1.5 px-3 py-1.5 -ml-3 rounded-md hover:bg-indigo-50 dark:hover:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 transition-colors border border-transparent hover:border-indigo-100 dark:hover:border-indigo-800"
                                   title="Ordenar por Apellidos">
                                    Apellidos
                                    <% if (typeof sortOrder !== 'undefined' && sortOrder === 'asc') { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
                                    <% } else if (typeof sortOrder !== 'undefined' && sortOrder === 'desc') { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 dark:text-slate-500"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
                                    <% } %>
                                </a>
                            </th>

                            <th class="p-4 font-semibold whitespace-nowrap">Rol</th>
                            <th class="p-4 font-semibold whitespace-nowrap">Estado y Hora</th>
                            <th class="p-4 font-semibold text-right whitespace-nowrap">Acción</th>
                        </tr>
                    </thead>
                    <tbody id="attendeesTableBody" class="divide-y divide-slate-100 dark:divide-slate-700/50">
                        <% if (attendees.length === 0) { %>
                            <tr id="noDataRow"><td colspan="6" class="p-8 text-center text-slate-500 dark:text-slate-400">No hay asistentes registrados en la base de datos.</td></tr>
                        <% } else { %>
                            <% attendees.forEach(function(a) { %>
                                <% 
                                    const isEdited = (typeof editedTicket !== 'undefined' && editedTicket === a.ticket); 
                                    const searchData = `${a.ticket} ${a.id_doc} ${a.first_name} ${a.last_name}`.toLowerCase();
                                %>
                                <tr class="attendee-row hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors <%= isEdited ? 'bg-indigo-50 dark:bg-indigo-900/40' : '' %>" data-search="<%= searchData %>">
                                    <td class="p-4">
                                        <button type="button" 
                                                onclick="openDetailsModal(this)" 
                                                data-attendee="<%= encodeURIComponent(JSON.stringify(a)) %>"
                                                class="font-bold text-lg text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 hover:underline transition-colors focus:outline-none focus:ring-2 focus:ring-indigo-500 rounded px-1 -ml-1">
                                            <%= a.ticket %>
                                        </button>
                                        <div class="text-xs text-slate-500 dark:text-slate-400 mt-1"><%= a.id_doc_type %>: <%= a.id_doc %></div>
                                    </td>
                                    <td class="p-4 font-medium text-slate-800 dark:text-slate-200">
                                        <%= a.first_name %>
                                        <% if (a.church) { %>
                                            <div class="text-xs text-slate-500 dark:text-slate-400 font-normal mt-0.5 whitespace-nowrap"><%= a.church %></div>
                                        <% } %>
                                    </td>
                                    <td class="p-4 font-medium text-slate-800 dark:text-slate-200"><%= a.last_name %></td>
                                    <td class="p-4">
                                        <% 
                                            let roleClass = 'bg-slate-100 dark:bg-slate-700 text-slate-800 dark:text-slate-200 border-slate-200 dark:border-slate-600';
                                            let roleName = a.role;
                                            if (a.role === 'Pastor') { roleClass = 'bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 border-blue-200 dark:border-blue-800'; }
                                            else if (a.role === 'Leader') { roleClass = 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-800 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800'; roleName = 'Líder'; }
                                            else if (a.role === 'Cordinador') { roleClass = 'bg-purple-100 dark:bg-purple-900/40 text-purple-800 dark:text-purple-300 border-purple-200 dark:border-purple-800'; roleName = 'Coordinador'; }
                                            else if (a.role === 'Voluntario') { roleClass = 'bg-pink-100 dark:bg-pink-900/40 text-pink-800 dark:text-pink-300 border-pink-200 dark:border-pink-800'; }
                                            else if (a.role === 'Public') { roleClass = 'bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-300 border-amber-200 dark:border-amber-800'; roleName = 'Público'; }
                                        %>
                                        <span class="px-2.5 py-1 rounded-full border text-xs font-bold whitespace-nowrap shadow-sm transition-colors <%= roleClass %>">
                                            <%= roleName %>
                                        </span>
                                    </td>
                                    <td class="p-4">
                                        <% if (a.is_present) { %>
                                            <div class="flex flex-col items-start gap-1">
                                                <span class="inline-flex items-center gap-1 text-emerald-600 dark:text-emerald-400 text-sm font-semibold bg-emerald-50 dark:bg-emerald-900/30 px-2 py-1 rounded-full"><i data-lucide="check-circle" class="w-4 h-4"></i> Adentro</span>
                                                <% if (a.check_in_time) { %>
                                                    <span class="text-[11px] text-slate-500 dark:text-slate-400 font-medium ml-1"><i data-lucide="clock" class="w-3 h-3 inline mr-0.5"></i><%= new Date(a.check_in_time).toLocaleString('es-CO', { day: '2-digit', month: 'short', hour: '2-digit', minute:'2-digit' }) %></span>
                                                <% } %>
                                            </div>
                                        <% } else { %>
                                            <span class="inline-flex items-center gap-1 text-amber-600 dark:text-amber-400 text-sm font-semibold bg-amber-50 dark:bg-amber-900/30 px-2 py-1 rounded-full"><i data-lucide="x-circle" class="w-4 h-4"></i> Pendiente</span>
                                        <% } %>
                                    </td>
                                    <td class="p-4 text-right">
                                        <% if (a.is_present) { %>
                                            <button disabled class="px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-400 dark:text-slate-500 rounded-lg text-sm font-medium cursor-not-allowed">Ya Ingresó</button>
                                        <% } else { %>
                                            <form action="/checkin" method="POST" class="inline">
                                                <input type="hidden" name="ticket" value="<%= a.ticket %>">
                                                <button type="submit" class="px-4 py-2 bg-emerald-600 text-white rounded-lg text-sm font-medium hover:bg-emerald-700 shadow-sm transition-all">Marcar Entrada</button>
                                            </form>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                        <tr id="emptySearchRow" class="hidden">
                            <td colspan="6" class="p-12 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <i data-lucide="search-x" class="w-12 h-12 text-slate-300 dark:text-slate-600 mb-3"></i>
                                    <p class="text-slate-500 dark:text-slate-400 text-lg">No se encontró a nadie para "<span id="emptySearchTerm" class="font-bold text-slate-700 dark:text-slate-300"></span>"</p>
                                    <p class="text-slate-400 dark:text-slate-500 text-sm mt-1">Verifique si escribió correctamente el nombre o el ticket.</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    <% } %>
</div>

<!-- ============================================== -->
<!-- MODAL DE DETALLES DEL ASISTENTE                -->
<!-- ============================================== -->
<div id="detailsModal" class="hidden fixed inset-0 bg-slate-900/60 dark:bg-slate-950/80 backdrop-blur-sm z-[150] flex items-center justify-center p-4 animate-in fade-in transition-colors">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl w-full max-w-2xl overflow-hidden animate-in zoom-in duration-200 transition-colors border border-slate-200 dark:border-slate-700 flex flex-col max-h-[90vh]">
        
        <div class="p-5 sm:px-8 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center bg-slate-50 dark:bg-slate-900/50 transition-colors">
            <h3 class="text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2">
                <i data-lucide="user" class="text-indigo-600 dark:text-indigo-400 w-6 h-6"></i> Detalles del Asistente
            </h3>
            <button type="button" onclick="closeDetailsModal()" class="text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300 transition-colors p-1 rounded-md hover:bg-slate-200 dark:hover:bg-slate-800">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
        </div>
        
        <div class="p-5 sm:px-8 overflow-y-auto flex-1 space-y-6">
            <div class="flex items-center gap-4 p-4 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl border border-indigo-100 dark:border-indigo-800/50">
                <div class="bg-white dark:bg-slate-800 p-3 rounded-lg shadow-sm border border-slate-100 dark:border-slate-700">
                    <i data-lucide="ticket" class="w-8 h-8 text-indigo-500 dark:text-indigo-400"></i>
                </div>
                <div>
                    <p class="text-xs font-semibold text-indigo-600 dark:text-indigo-400 uppercase tracking-wider">Ticket / Boleto</p>
                    <p id="det-ticket" class="text-2xl font-extrabold text-slate-800 dark:text-white tracking-tight"></p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-6 gap-x-4">
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">Nombres</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-firstname"></strong>
                </div>
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">Apellidos</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-lastname"></strong>
                </div>
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">Documento</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-doc"></strong>
                </div>
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">Iglesia / Congregación</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-church"></strong>
                </div>
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">Correo Electrónico</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-email"></strong>
                </div>
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">Teléfono</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-phone"></strong>
                </div>
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">País</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-country"></strong>
                </div>
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">Sexo</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-sex"></strong>
                </div>
                <div class="sm:col-span-2">
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-1">Dirección</span>
                    <strong class="text-slate-800 dark:text-slate-200 text-base block" id="det-address"></strong>
                </div>
            </div>

            <div class="flex gap-4 pt-2">
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-2">Rol Asignado</span>
                    <span id="det-role" class="px-3 py-1.5 rounded-lg border text-sm font-bold shadow-sm bg-slate-100 dark:bg-slate-700 text-slate-800 dark:text-slate-200 border-slate-200 dark:border-slate-600 uppercase"></span>
                </div>
                <div>
                    <span class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-2">Estado de Ingreso</span>
                    <span id="det-status" class="px-3 py-1.5 rounded-lg border text-sm font-bold shadow-sm"></span>
                </div>
            </div>

            <div class="pt-4 border-t border-slate-100 dark:border-slate-700 transition-colors">
                <label class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider block mb-2">Observaciones</label>
                <div id="det-observations" class="p-4 bg-slate-50 dark:bg-slate-900/50 rounded-xl text-slate-800 dark:text-slate-300 min-h-[80px] whitespace-pre-wrap border border-slate-100 dark:border-slate-700 text-sm"></div>
            </div>
            
        </div>
        
        <div class="p-5 sm:px-8 border-t border-slate-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50 flex flex-col sm:flex-row justify-end gap-3 transition-colors">
            <button type="button" onclick="closeDetailsModal()" class="w-full sm:w-auto px-6 py-2.5 bg-slate-200 dark:bg-slate-700 text-slate-800 dark:text-slate-200 rounded-lg font-semibold hover:bg-slate-300 dark:hover:bg-slate-600 transition-colors text-center">Cerrar Ficha</button>
            
            <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
                <button type="button" id="det-delete-btn" class="w-full sm:w-auto px-6 py-2.5 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 shadow-md transition-all flex items-center justify-center gap-2">
                    <i data-lucide="trash-2" class="w-4 h-4"></i> Eliminar
                </button>
                <button type="button" id="det-modify-btn" class="w-full sm:w-auto px-6 py-2.5 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700 shadow-md transition-all flex items-center justify-center gap-2">
                    <i data-lucide="edit" class="w-4 h-4"></i> Modificar Registro
                </button>
            <% } %>
        </div>
    </div>
</div>

<!-- ============================================== -->
<!-- MODAL DE CONFIRMACIÓN DE ELIMINACIÓN           -->
<!-- ============================================== -->
<div id="deleteConfirmModal" class="hidden fixed inset-0 bg-slate-900/60 dark:bg-slate-950/80 backdrop-blur-sm z-[200] flex items-center justify-center p-4 animate-in fade-in transition-colors">
    <div class="bg-white dark:bg-slate-800 p-5 sm:p-8 rounded-xl shadow-2xl border-t-4 border-t-red-500 max-w-lg w-full text-center transition-colors animate-in zoom-in duration-200">
        <i data-lucide="alert-circle" class="w-16 h-16 text-red-500 mx-auto mb-4"></i>
        <h3 class="text-2xl font-bold text-slate-800 dark:text-white mb-2 transition-colors">Confirmar Eliminación</h3>
        <p class="text-slate-600 dark:text-slate-300 mb-6 transition-colors">
            Está a punto de eliminar permanentemente el registro de <br>
            <strong class="text-slate-800 dark:text-white" id="del-fullname"></strong> 
            <span class="whitespace-nowrap">(Ticket: <span id="del-ticket-display"></span>).</span>
        </p>
        
        <form action="/delete" method="POST" class="flex flex-col sm:flex-row justify-center gap-4">
            <input type="hidden" name="ticket" id="del-ticket-input">
            <!-- Este input oculto le dice al servidor que regrese a Consultas tras eliminar -->
            <input type="hidden" name="redirect" value="/consult">
            <button type="button" onclick="closeDeleteConfirmModal()" class="w-full sm:w-auto px-6 py-3 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg font-semibold hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors">Cancelar</button>
            <button type="submit" class="w-full sm:w-auto px-6 py-3 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 shadow-md transition-all">Sí, Eliminar Registro</button>
        </form>
    </div>
</div>

<!-- ============================================== -->
<!-- SCRIPTS: BÚSQUEDA EN VIVO Y MODAL              -->
<!-- ============================================== -->
<script>
    // LÓGICA DE BÚSQUEDA UNIVERSAL (Live Search)
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('liveSearchInput');
        const clearBtn = document.getElementById('clearSearchBtn');
        const rows = document.querySelectorAll('.attendee-row');
        const emptySearchRow = document.getElementById('emptySearchRow');
        const emptySearchTerm = document.getElementById('emptySearchTerm');

        if (!searchInput) return;

        clearBtn.addEventListener('click', () => {
            searchInput.value = '';
            filterTable('');
            searchInput.focus();
        });

        searchInput.addEventListener('input', (e) => {
            filterTable(e.target.value);
        });

        function filterTable(query) {
            const normalizedQuery = query.toLowerCase().trim();
            
            if (normalizedQuery.length > 0) {
                clearBtn.classList.remove('hidden');
            } else {
                clearBtn.classList.add('hidden');
            }

            let visibleCount = 0;

            rows.forEach(row => {
                const searchData = row.getAttribute('data-search');
                if (searchData.includes(normalizedQuery)) {
                    row.style.display = ''; 
                    visibleCount++;
                } else {
                    row.style.display = 'none'; 
                }
            });

            if (visibleCount === 0 && rows.length > 0) {
                emptySearchRow.classList.remove('hidden');
                emptySearchTerm.textContent = query;
                if (typeof lucide !== 'undefined') lucide.createIcons();
            } else {
                emptySearchRow.classList.add('hidden');
            }
        }
    });

    // LÓGICA DEL MODAL DE DETALLES (CON HORA Y ELIMINAR)
    function openDetailsModal(button) {
        const rawData = decodeURIComponent(button.getAttribute('data-attendee'));
        const attendee = JSON.parse(rawData);
        
        document.getElementById('det-ticket').textContent = attendee.ticket;
        document.getElementById('det-doc').textContent = `${attendee.id_doc_type} - ${attendee.id_doc}`;
        document.getElementById('det-firstname').textContent = attendee.first_name;
        document.getElementById('det-lastname').textContent = attendee.last_name;
        document.getElementById('det-sex').textContent = attendee.sex || 'No registrado';
        document.getElementById('det-church').textContent = attendee.church || 'No registrada';
        document.getElementById('det-email').textContent = attendee.email;
        document.getElementById('det-phone').textContent = attendee.phone || 'No registrado';
        document.getElementById('det-address').textContent = attendee.address || 'No registrada';
        document.getElementById('det-country').textContent = attendee.country;
        
        let roleName = attendee.role;
        if (roleName === 'Leader') roleName = 'Líder';
        if (roleName === 'Public') roleName = 'Público';
        if (roleName === 'Cordinador') roleName = 'Coordinador';
        document.getElementById('det-role').textContent = roleName;
        
        const statusEl = document.getElementById('det-status');
        if (attendee.is_present) {
            let timeStr = '';
            if (attendee.check_in_time) {
                const d = new Date(attendee.check_in_time);
                timeStr = ` (${d.toLocaleDateString('es-CO', {day:'2-digit', month:'short'})} a las ${d.toLocaleTimeString('es-CO', {hour:'2-digit', minute:'2-digit'})})`;
            }
            statusEl.textContent = '✅ Adentro' + timeStr;
            statusEl.className = 'px-3 py-1.5 rounded-lg border text-sm font-bold shadow-sm bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 border-emerald-200 dark:border-emerald-800';
        } else {
            statusEl.textContent = '⏳ Pendiente (No ha llegado)';
            statusEl.className = 'px-3 py-1.5 rounded-lg border text-sm font-bold shadow-sm bg-amber-50 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 border-amber-200 dark:border-amber-800';
        }

        const obsEl = document.getElementById('det-observations');
        if (attendee.observations && attendee.observations.trim() !== '') {
            obsEl.textContent = attendee.observations;
            obsEl.classList.remove('text-slate-400', 'italic');
        } else {
            obsEl.textContent = 'Sin observaciones especiales registradas para este asistente.';
            obsEl.classList.add('text-slate-400', 'italic');
        }
        
        const modBtn = document.getElementById('det-modify-btn');
        if (modBtn) {
            modBtn.onclick = function() {
                window.location.href = '/modify?ticket=' + encodeURIComponent(attendee.ticket);
            };
        }

        const delBtn = document.getElementById('det-delete-btn');
        if (delBtn) {
            // Asignamos la acción para abrir el modal de alerta roja
            delBtn.onclick = function() {
                openDeleteConfirmModal(attendee);
            };
        }
        
        if (typeof lucide !== 'undefined') lucide.createIcons();
        document.getElementById('detailsModal').classList.remove('hidden');
    }

    function closeDetailsModal() {
        document.getElementById('detailsModal').classList.add('hidden');
    }

    // Funciones para el Modal de Confirmación de Eliminación
    function openDeleteConfirmModal(attendee) {
        document.getElementById('del-fullname').textContent = attendee.first_name + ' ' + attendee.last_name;
        document.getElementById('del-ticket-display').textContent = attendee.ticket;
        document.getElementById('del-ticket-input').value = attendee.ticket;
        
        // Cerramos el modal de detalles para que no se superpongan
        closeDetailsModal();
        document.getElementById('deleteConfirmModal').classList.remove('hidden');
    }

    function closeDeleteConfirmModal() {
        document.getElementById('deleteConfirmModal').classList.add('hidden');
    }
</script>
