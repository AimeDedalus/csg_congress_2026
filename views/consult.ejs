<div class="animate-in slide-in-from-bottom-4">
    <h2 class="text-2xl font-bold text-slate-800 dark:text-white mb-6 flex items-center gap-2 transition-colors">
        <i data-lucide="search" class="text-indigo-600 dark:text-indigo-400"></i> Consultas y Control de Entrada
    </h2>
    
    <div class="bg-white dark:bg-slate-800 p-5 sm:p-6 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 mb-6 transition-colors">
        <form action="/consult" method="GET" class="flex flex-col md:flex-row gap-4">
            <div class="flex-1 relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <i data-lucide="search" class="h-5 w-5 text-slate-400"></i>
                </div>
                <input type="text" name="q" value="<%= typeof query !== 'undefined' ? query : '' %>" class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-300 dark:border-slate-600 focus:ring-2 focus:ring-indigo-500 outline-none bg-white dark:bg-slate-700 text-slate-800 dark:text-white placeholder-slate-400 transition-all" placeholder="Buscar asistentes...">
                <input type="hidden" name="sort" value="<%= typeof sortOrder !== 'undefined' ? sortOrder : '' %>">
            </div>
            <select name="field" class="px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-600 focus:ring-2 focus:ring-indigo-500 outline-none bg-slate-50 dark:bg-slate-700 text-slate-800 dark:text-white min-w-[220px] transition-colors">
                <option value="ticket" <%= typeof field !== 'undefined' && field == 'ticket' ? 'selected' : '' %>>Buscar por Número de Ticket</option>
                <option value="id_doc" <%= typeof field !== 'undefined' && field == 'id_doc' ? 'selected' : '' %>>Buscar por Documento</option>
                <option value="last_name" <%= typeof field !== 'undefined' && field == 'last_name' ? 'selected' : '' %>>Buscar por Apellidos</option>
                <option value="first_name" <%= typeof field !== 'undefined' && field == 'first_name' ? 'selected' : '' %>>Buscar por Nombres</option>
            </select>
            <button type="submit" class="px-6 py-3 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700 shadow-md transition-all">Buscar</button>
        </form>
    </div>

    <% if (typeof attendees !== 'undefined') { %>
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden transition-colors">
            
            <!-- CONTENEDOR CON SCROLL Y ALTURA MÁXIMA PARA ACTIVAR STICKY HEADER -->
            <div class="overflow-auto w-full max-h-[65vh]">
                <table class="w-full text-left border-collapse min-w-[600px] relative">
                    
                    <!-- CABECERA FIJA (STICKY) -->
                    <thead class="sticky top-0 z-20 shadow-sm">
                        <tr class="bg-slate-100 dark:bg-slate-900 text-slate-600 dark:text-slate-300 text-sm border-b border-slate-200 dark:border-slate-700 transition-colors">
                            <th class="p-4 font-semibold whitespace-nowrap">Ticket y Doc</th>
                            <th class="p-4 font-semibold whitespace-nowrap">Nombres e Iglesia</th>
                            
                            <th class="p-4 font-semibold whitespace-nowrap">
                                <% const nextSort = (typeof sortOrder !== 'undefined' && sortOrder === 'asc') ? 'desc' : 'asc'; %>
                                <a href="/consult?q=<%= typeof query !== 'undefined' ? query : '' %>&field=<%= typeof field !== 'undefined' ? field : 'ticket' %>&sort=<%= nextSort %>" 
                                   class="inline-flex items-center gap-1.5 px-3 py-1.5 -ml-3 rounded-md hover:bg-indigo-50 dark:hover:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 transition-colors border border-transparent hover:border-indigo-100 dark:hover:border-indigo-800">
                                    Apellidos
                                    <% if (typeof sortOrder !== 'undefined' && sortOrder === 'asc') { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
                                    <% } else if (typeof sortOrder !== 'undefined' && sortOrder === 'desc') { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg>
                                    <% } else { %>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 dark:text-slate-500"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
                                    <% } %>
                                </a>
                            </th>

                            <th class="p-4 font-semibold whitespace-nowrap">Rol</th>
                            <th class="p-4 font-semibold whitespace-nowrap">Estado</th>
                            <th class="p-4 font-semibold text-right whitespace-nowrap">Acción</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-700/50">
                        <% if (attendees.length === 0) { %>
                            <tr><td colspan="6" class="p-8 text-center text-slate-500 dark:text-slate-400">No se encontraron asistentes <% if (typeof query !== 'undefined' && query) { %>que coincidan con "<%= query %>"<% } %></td></tr>
                        <% } else { %>
                            <% attendees.forEach(function(a) { %>
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                    <td class="p-4">
                                        <div class="font-medium text-indigo-600 dark:text-indigo-400"><%= a.ticket %></div>
                                        <div class="text-xs text-slate-500 dark:text-slate-400"><%= a.id_doc_type %>: <%= a.id_doc %></div>
                                    </td>
                                    <td class="p-4 font-medium text-slate-800 dark:text-slate-200">
                                        <%= a.first_name %>
                                        <% if (a.church) { %>
                                            <div class="text-xs text-slate-500 dark:text-slate-400 font-normal mt-0.5 whitespace-nowrap"><%= a.church %></div>
                                        <% } %>
                                    </td>
                                    <td class="p-4 font-medium text-slate-800 dark:text-slate-200"><%= a.last_name %></td>
                                    <td class="p-4">
                                        <% 
                                            let roleClass = 'bg-slate-100 dark:bg-slate-700 text-slate-800 dark:text-slate-200 border-slate-200 dark:border-slate-600';
                                            let roleName = a.role;
                                            if (a.role === 'Pastor') { roleClass = 'bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 border-blue-200 dark:border-blue-800'; }
                                            else if (a.role === 'Leader') { roleClass = 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-800 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800'; roleName = 'Líder'; }
                                            else if (a.role === 'Cordinador') { roleClass = 'bg-purple-100 dark:bg-purple-900/40 text-purple-800 dark:text-purple-300 border-purple-200 dark:border-purple-800'; roleName = 'Coordinador'; }
                                            else if (a.role === 'Voluntario') { roleClass = 'bg-pink-100 dark:bg-pink-900/40 text-pink-800 dark:text-pink-300 border-pink-200 dark:border-pink-800'; }
                                            else if (a.role === 'Public') { roleClass = 'bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-300 border-amber-200 dark:border-amber-800'; roleName = 'Público'; }
                                        %>
                                        <span class="px-2.5 py-1 rounded-full border text-xs font-bold whitespace-nowrap shadow-sm transition-colors <%= roleClass %>">
                                            <%= roleName %>
                                        </span>
                                    </td>
                                    <td class="p-4">
                                        <% if (a.is_present) { %>
                                            <span class="inline-flex items-center gap-1 text-emerald-600 dark:text-emerald-400 text-sm font-semibold bg-emerald-50 dark:bg-emerald-900/30 px-2 py-1 rounded-full"><i data-lucide="check-circle" class="w-4 h-4"></i> Adentro</span>
                                        <% } else { %>
                                            <span class="inline-flex items-center gap-1 text-amber-600 dark:text-amber-400 text-sm font-semibold bg-amber-50 dark:bg-amber-900/30 px-2 py-1 rounded-full"><i data-lucide="x-circle" class="w-4 h-4"></i> Pendiente</span>
                                        <% } %>
                                    </td>
                                    <td class="p-4 text-right">
                                        <% if (a.is_present) { %>
                                            <button disabled class="px-4 py-2 bg-slate-100 dark:bg-slate-700 text-slate-400 dark:text-slate-500 rounded-lg text-sm font-medium cursor-not-allowed">Ya Ingresó</button>
                                        <% } else { %>
                                            <form action="/checkin" method="POST" class="inline">
                                                <input type="hidden" name="ticket" value="<%= a.ticket %>">
                                                <button type="submit" class="px-4 py-2 bg-emerald-600 text-white rounded-lg text-sm font-medium hover:bg-emerald-700 shadow-sm transition-all">Marcar Entrada</button>
                                            </form>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    <% } %>
</div>
