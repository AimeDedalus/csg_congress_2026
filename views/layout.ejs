<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="#312e81">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title><%= title %> - Congreso CSG App</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Configuración para habilitar clases 'dark:' en Tailwind -->
    <script>
        window.tailwind = window.tailwind || {};
        window.tailwind.config = { darkMode: 'class' };
    </script>

    <style>
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideInFromBottom { from { transform: translateY(1rem); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes zoomIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .animate-in.fade-in { animation: fadeIn 0.3s ease-in-out; }
        .animate-in.slide-in-from-bottom-4 { animation: slideInFromBottom 0.3s ease-out; }
        .animate-in.zoom-in { animation: zoomIn 0.5s ease-out; }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .pb-nav-safe { padding-bottom: max(env(safe-area-inset-bottom), 0.75rem); }
    </style>
</head>

<!-- Fondo general transiciona suavemente entre claro y oscuro -->
<body class="flex flex-col md:flex-row h-[100dvh] w-full bg-slate-50 dark:bg-slate-900 font-sans text-slate-800 dark:text-slate-200 overflow-hidden transition-colors duration-300">
    
    <!-- MOBILE HEADER -->
    <header class="md:hidden w-full bg-indigo-950 text-white flex items-center justify-between p-4 flex-shrink-0 z-20 shadow-md">
        <div class="flex items-center gap-2">
            <h1 class="text-lg font-bold">CTG App</h1>
        </div>
        
        <div class="flex items-center gap-3">
            <!-- BOTÓN MODO OSCURO MÓVIL -->
            <button onclick="toggleGlobalDarkMode()" class="text-indigo-300 hover:text-white transition-colors bg-indigo-900/50 p-1.5 rounded-lg border border-indigo-800">
                <i data-lucide="moon" id="darkModeIconMob" class="w-5 h-5"></i>
            </button>

            <% if (user) { %>
                <span class="text-xs font-medium text-indigo-200"><%= user.username %></span>
                <a href="/logout" class="text-red-400 hover:text-red-300 transition-colors bg-indigo-900/50 p-1.5 rounded-lg border border-indigo-800">
                    <i data-lucide="log-out" class="w-5 h-5"></i>
                </a>
            <% } else { %>
                <a href="/login" class="text-indigo-300 hover:text-white transition-colors bg-indigo-900/50 p-1.5 rounded-lg border border-indigo-800">
                    <i data-lucide="lock" class="w-5 h-5"></i>
                </a>
            <% } %>
        </div>
    </header>

    <!-- SIDEBAR NAVIGATION (Desktop) -->
    <nav class="w-64 bg-indigo-900 dark:bg-slate-950 text-white flex-col shadow-xl z-20 hidden md:flex flex-shrink-0 transition-colors">
        <div class="p-6 bg-indigo-950 flex items-center gap-3">
            <h1 class="text-xl font-bold leading-tight">Congreso Cristiano<br/>CTG App</h1>
        </div>
        
        <div class="flex flex-col py-4 gap-1 px-3 flex-1 overflow-y-auto min-h-0">
            <a href="/" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Inicio' ? 'bg-indigo-600 text-white shadow-md' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                <i data-lucide="home" class="w-5 h-5"></i><span>Inicio</span>
            </a>
            
            <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
            <a href="/dashboard" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Panel de Control' ? 'bg-indigo-600 text-white shadow-md' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                <i data-lucide="layout-dashboard" class="w-5 h-5"></i><span>Panel de Control</span>
            </a>
            <a href="/reports" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Reportes' ? 'bg-indigo-600 text-white shadow-md' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                <i data-lucide="file-text" class="w-5 h-5"></i><span>Reportes</span>
            </a>
            <div class="my-2 border-t border-indigo-800 dark:border-slate-800"></div>
            <a href="/register" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Registro' ? 'bg-indigo-600 text-white shadow-md' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                <i data-lucide="user-plus" class="w-5 h-5"></i><span>Registrar Asistente</span>
            </a>
            <% } %>

            <% if (user) { %>
            <a href="/consult" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Consultas y Check-In' ? 'bg-indigo-600 text-white shadow-md' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                <i data-lucide="search" class="w-5 h-5"></i><span>Consultas y Entrada</span>
            </a>
            <% } %>
            
            <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
            <a href="/modify" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Modificar Registro' ? 'bg-indigo-600 text-white shadow-md' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                <i data-lucide="edit" class="w-5 h-5"></i><span>Modificar Detalles</span>
            </a>
            <a href="/delete" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Eliminar Registro' ? 'bg-indigo-600 text-white shadow-md' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                <i data-lucide="trash-2" class="w-5 h-5"></i><span>Eliminar Registro</span>
            </a>
            <% } %>

            <% if (user && user.role === 'superadmin') { %>
            <div class="my-2 border-t border-indigo-800 dark:border-slate-800"></div>
            <a href="/users" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Gestión de Usuarios' ? 'bg-indigo-600 text-white shadow-md' : 'text-amber-400 hover:bg-indigo-800 hover:text-amber-300' %>">
                <i data-lucide="user-cog" class="w-5 h-5"></i><span>Gestión Usuarios</span>
            </a>
            <a href="/logs" class="flex items-center gap-3 w-full px-4 py-3 rounded-lg transition-colors text-left font-medium <%= title === 'Registro de Actividad' ? 'bg-indigo-600 text-white shadow-md' : 'text-amber-400 hover:bg-indigo-800 hover:text-amber-300' %>">
                <i data-lucide="activity" class="w-5 h-5"></i><span>Registro Actividad</span>
            </a>
            <% } %>
        </div>

        <div class="px-4 pb-6 mt-auto">
            <!-- BOTÓN MODO OSCURO DESKTOP -->
            <button onclick="toggleGlobalDarkMode()" class="flex items-center justify-center gap-2 w-full px-4 py-2.5 mb-4 bg-indigo-950 hover:bg-indigo-800 text-indigo-200 hover:text-white rounded-lg transition-colors text-sm font-medium border border-indigo-800">
                <i data-lucide="moon" id="darkModeIconDesk" class="w-4 h-4"></i> <span id="darkModeTextDesk">Modo Oscuro</span>
            </button>

            <% if (user) { %>
                <div class="mb-3 text-center text-xs text-indigo-300">
                    Usuario: <strong class="text-white"><%= user.username %></strong> (<%= user.role %>)
                </div>
                <a href="/logout" class="flex items-center justify-center gap-2 w-full px-4 py-2 bg-indigo-800 hover:bg-indigo-700 text-indigo-200 hover:text-white rounded-lg transition-colors text-sm font-medium">
                    <i data-lucide="log-out" class="w-4 h-4"></i> Cerrar Sesión
                </a>
            <% } else { %>
                <a href="/login" class="flex items-center justify-center gap-2 w-full px-4 py-2 bg-indigo-800 hover:bg-indigo-700 text-indigo-200 hover:text-white rounded-lg transition-colors text-sm font-medium">
                    <i data-lucide="lock" class="w-4 h-4"></i> Iniciar Sesión
                </a>
            <% } %>
        </div>
    </nav>

    <!-- MAIN CONTENT AREA -->
    <main class="flex-1 relative min-w-0 w-full overflow-x-hidden overflow-y-auto">
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="absolute top-4 right-4 p-4 rounded-lg shadow-lg flex items-center gap-3 z-[110] text-white bg-emerald-600 animate-in fade-in mx-4 sm:mx-0">
                <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
                <span class="font-medium text-sm sm:text-base"><%= success %></span>
            </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="absolute top-4 right-4 p-4 rounded-lg shadow-lg flex items-center gap-3 z-[110] text-white bg-red-600 animate-in fade-in mx-4 sm:mx-0">
                <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
                <span class="font-medium text-sm sm:text-base"><%= error %></span>
            </div>
        <% } %>

        <div class="p-4 sm:p-6 md:p-10 w-full max-w-6xl mx-auto h-full pb-8">
            <%- body %>
        </div>
    </main>

    <!-- MOBILE NAVIGATION (Scrollable) -->
    <nav class="md:hidden w-full bg-indigo-900 dark:bg-slate-950 text-white flex flex-shrink-0 overflow-x-auto no-scrollbar items-center justify-start pt-3 px-4 gap-5 z-20 shadow-[0_-4px_10px_-1px_rgba(0,0,0,0.2)] pb-nav-safe border-t border-indigo-800 transition-colors">
        <a href="/" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Inicio' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="home" class="w-6 h-6"></i></a>
        
        <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
        <a href="/dashboard" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Panel de Control' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="layout-dashboard" class="w-6 h-6"></i></a>
        <a href="/register" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Registro' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="user-plus" class="w-6 h-6"></i></a>
        
        <a href="/modify" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Modificar Registro' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="edit" class="w-6 h-6"></i></a>
        <a href="/delete" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Eliminar Registro' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="trash-2" class="w-6 h-6"></i></a>
        <% } %>
        
        <% if (user) { %>
        <a href="/consult" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Consultas y Check-In' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="search" class="w-6 h-6"></i></a>
        <% } %>

        <% if (user && user.role === 'superadmin') { %>
        <a href="/users" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Gestión de Usuarios' ? 'bg-indigo-600 text-white' : 'text-amber-400' %>"><i data-lucide="user-cog" class="w-6 h-6"></i></a>
        <a href="/logs" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Registro de Actividad' ? 'bg-indigo-600 text-white' : 'text-amber-400' %>"><i data-lucide="activity" class="w-6 h-6"></i></a>
        <% } %>
    </nav>

    <!-- SCRIPT GLOBAL MODO OSCURO -->
    <script>
        function initGlobalDarkMode() {
            const isDark = localStorage.getItem('darkMode') === 'true';
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
            updateGlobalDarkModeUI(isDark);
        }

        function toggleGlobalDarkMode() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('darkMode', isDark);
            updateGlobalDarkModeUI(isDark);
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        function updateGlobalDarkModeUI(isDark) {
            const deskIcon = document.getElementById('darkModeIconDesk');
            const deskText = document.getElementById('darkModeTextDesk');
            const mobIcon = document.getElementById('darkModeIconMob');
            
            if (deskIcon) deskIcon.setAttribute('data-lucide', isDark ? 'sun' : 'moon');
            if (deskText) deskText.textContent = isDark ? 'Modo Claro' : 'Modo Oscuro';
            if (mobIcon) mobIcon.setAttribute('data-lucide', isDark ? 'sun' : 'moon');
        }

        document.addEventListener('DOMContentLoaded', initGlobalDarkMode);
        lucide.createIcons();
    </script>
</body>
</html>
