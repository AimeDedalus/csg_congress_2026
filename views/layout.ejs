<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="#312e81">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title><%= title %> - Congreso Cristiano CSG App</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- FUENTE PREMIUM PLUS JAKARTA SANS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <script>
        window.tailwind = window.tailwind || {};
        window.tailwind.config = { 
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['"Plus Jakarta Sans"', 'sans-serif'],
                    }
                }
            }
        };
    </script>

    <style>
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideInFromBottom { from { transform: translateY(1rem); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes zoomIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .animate-in.fade-in { animation: fadeIn 0.3s ease-in-out; }
        .animate-in.slide-in-from-bottom-4 { animation: slideInFromBottom 0.3s ease-out; }
        .animate-in.zoom-in { animation: zoomIn 0.5s ease-out; }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .pb-nav-safe { padding-bottom: max(env(safe-area-inset-bottom), 0.75rem); }
        .pb-safe { padding-bottom: calc(env(safe-area-inset-bottom) + 5rem); }

        /* CORRECCIÓN GLOBAL: Evita que el autocompletado ponga fondo blanco en Modo Oscuro */
        .dark input:-webkit-autofill,
        .dark input:-webkit-autofill:hover, 
        .dark input:-webkit-autofill:focus, 
        .dark input:-webkit-autofill:active,
        .dark select:-webkit-autofill,
        .dark select:-webkit-autofill:hover,
        .dark select:-webkit-autofill:focus {
            -webkit-box-shadow: 0 0 0 30px #334155 inset !important;
            -webkit-text-fill-color: white !important;
            transition: background-color 5000s ease-in-out 0s;
        }
    </style>

    <!-- SOLUCIÓN AL PARPADEO (FOUC): Revisa el modo oscuro ANTES de cargar el body -->
    <script>
        if (localStorage.getItem('darkMode') === 'true') {
            document.documentElement.classList.add('dark');
        }
    </script>
</head>

<body class="flex flex-col h-[100dvh] w-full bg-slate-50 dark:bg-slate-900 font-sans text-slate-800 dark:text-slate-200 overflow-hidden transition-colors duration-300">
    
    <!-- HEADER MÓVIL (Solo visible en celulares) -->
    <header class="md:hidden w-full bg-indigo-950 text-white flex items-center justify-between p-4 flex-shrink-0 z-20 shadow-md">
        <div class="flex items-center gap-2">
            <h1 class="text-lg font-bold tracking-tight">CSG App</h1>
        </div>
        
        <div class="flex items-center gap-3">
            <button onclick="toggleGlobalDarkMode()" class="text-indigo-300 hover:text-white transition-colors bg-indigo-900/50 p-1.5 rounded-lg border border-indigo-800">
                <i data-lucide="moon" id="darkModeIconMob" class="w-5 h-5"></i>
            </button>

            <% if (user) { %>
                <span class="text-xs font-medium text-indigo-200"><%= user.username %></span>
                <a href="/logout" class="text-red-400 hover:text-red-300 transition-colors bg-indigo-900/50 p-1.5 rounded-lg border border-indigo-800">
                    <i data-lucide="log-out" class="w-5 h-5"></i>
                </a>
            <% } else { %>
                <a href="/login" class="text-indigo-300 hover:text-white transition-colors bg-indigo-900/50 p-1.5 rounded-lg border border-indigo-800">
                    <i data-lucide="lock" class="w-5 h-5"></i>
                </a>
            <% } %>
        </div>
    </header>

    <!-- HEADER DESKTOP / TOP NAVBAR -->
    <header class="hidden md:flex w-full bg-indigo-900 dark:bg-slate-950 text-white items-center justify-between px-6 py-3 shadow-md z-20 flex-shrink-0 transition-colors border-b border-indigo-800 dark:border-slate-800">
        
        <div class="flex items-center gap-6 overflow-hidden">
            <div class="flex items-center gap-2 pr-6 border-r border-indigo-700 dark:border-slate-800 flex-shrink-0">
                <h1 class="text-xl font-bold tracking-tight">CSG App</h1>
            </div>
            
            <nav class="flex items-center gap-1 overflow-x-auto no-scrollbar">
                <a href="/" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap <%= title === 'Inicio' ? 'bg-indigo-600 text-white shadow-sm' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                    <i data-lucide="home" class="w-4 h-4"></i>Inicio
                </a>
                
                <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
                <a href="/dashboard" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap <%= title === 'Panel de Control' ? 'bg-indigo-600 text-white shadow-sm' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                    <i data-lucide="layout-dashboard" class="w-4 h-4"></i>Panel
                </a>
                <a href="/reports" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap <%= title === 'Reportes' ? 'bg-indigo-600 text-white shadow-sm' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                    <i data-lucide="file-text" class="w-4 h-4"></i>Reportes
                </a>
                <a href="/register" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap <%= title === 'Registro' ? 'bg-indigo-600 text-white shadow-sm' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                    <i data-lucide="user-plus" class="w-4 h-4"></i>Registro
                </a>
                <% } %>

                <% if (user) { %>
                <a href="/consult" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap <%= title === 'Consultas y Check-In' ? 'bg-indigo-600 text-white shadow-sm' : 'text-indigo-200 hover:bg-indigo-800 hover:text-white' %>">
                    <i data-lucide="search" class="w-4 h-4"></i>Consultas
                </a>
                <% } %>

                <% if (user && user.role === 'superadmin') { %>
                <div class="h-5 w-px bg-indigo-700 dark:bg-slate-800 mx-2 hidden lg:block"></div>
                <a href="/users" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap <%= title === 'Gestión de Usuarios' ? 'bg-indigo-600 text-white shadow-sm' : 'text-amber-400 hover:bg-indigo-800 hover:text-amber-300' %>">
                    <i data-lucide="user-cog" class="w-4 h-4"></i>Usuarios
                </a>
                <a href="/logs" class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap <%= title === 'Registro de Actividad' ? 'bg-indigo-600 text-white shadow-sm' : 'text-amber-400 hover:bg-indigo-800 hover:text-amber-300' %>">
                    <i data-lucide="activity" class="w-4 h-4"></i>Logs
                </a>
                <% } %>
            </nav>
        </div>

        <div class="flex items-center gap-4 flex-shrink-0 ml-4">
            <button onclick="toggleGlobalDarkMode()" class="text-indigo-300 hover:text-white transition-colors bg-indigo-900/50 dark:bg-slate-800 p-2 rounded-lg border border-indigo-800 dark:border-slate-700">
                <i data-lucide="moon" id="darkModeIconDesk" class="w-4 h-4"></i>
            </button>

            <% if (user) { %>
                <div class="flex items-center gap-4 pl-4 border-l border-indigo-700 dark:border-slate-800">
                    <div class="text-right hidden lg:block">
                        <p class="text-sm font-bold leading-none text-white"><%= user.username %></p>
                        <p class="text-[11px] text-indigo-300 capitalize mt-1 tracking-wide"><%= user.role %></p>
                    </div>
                    <a href="/logout" class="flex items-center gap-2 px-3 py-2 bg-red-500/10 text-red-400 hover:bg-red-500 hover:text-white rounded-lg transition-colors text-sm font-medium border border-red-500/20 shadow-sm">
                        <i data-lucide="log-out" class="w-4 h-4"></i> <span class="hidden lg:inline">Salir</span>
                    </a>
                </div>
            <% } else { %>
                <a href="/login" class="flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg transition-colors text-sm font-medium shadow-sm">
                    <i data-lucide="lock" class="w-4 h-4"></i> Iniciar Sesión
                </a>
            <% } %>
        </div>
    </header>

    <!-- AREA DE CONTENIDO PRINCIPAL -->
    <main class="flex-1 relative min-w-0 w-full overflow-x-hidden overflow-y-auto pb-safe md:pb-0">
        
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="absolute top-4 right-4 p-4 rounded-lg shadow-lg flex items-center gap-3 z-[110] text-white bg-emerald-600 animate-in fade-in mx-4 sm:mx-0">
                <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i>
                <span class="font-medium text-sm sm:text-base"><%= success %></span>
            </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="absolute top-4 right-4 p-4 rounded-lg shadow-lg flex items-center gap-3 z-[110] text-white bg-red-600 animate-in fade-in mx-4 sm:mx-0">
                <i data-lucide="alert-circle" class="w-5 h-5 flex-shrink-0"></i>
                <span class="font-medium text-sm sm:text-base"><%= error %></span>
            </div>
        <% } %>

        <div class="p-4 sm:p-6 md:p-10 w-full max-w-6xl mx-auto h-full pb-8">
            <%- body %>
        </div>
    </main>

    <!-- NAVEGACIÓN MÓVIL INFERIOR -->
    <nav class="md:hidden w-full bg-indigo-900 dark:bg-slate-950 text-white flex flex-shrink-0 overflow-x-auto no-scrollbar items-center justify-start pt-3 px-4 gap-5 z-20 shadow-[0_-4px_10px_-1px_rgba(0,0,0,0.2)] pb-nav-safe border-t border-indigo-800 transition-colors">
        <a href="/" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Inicio' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="home" class="w-6 h-6"></i></a>
        
        <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
        <a href="/dashboard" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Panel de Control' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="layout-dashboard" class="w-6 h-6"></i></a>
        <a href="/register" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Registro' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="user-plus" class="w-6 h-6"></i></a>
        <% } %>
        
        <% if (user) { %>
        <a href="/consult" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Consultas y Check-In' ? 'bg-indigo-600 text-white' : 'text-indigo-300' %>"><i data-lucide="search" class="w-6 h-6"></i></a>
        <% } %>

        <% if (user && user.role === 'superadmin') { %>
        <a href="/users" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Gestión de Usuarios' ? 'bg-indigo-600 text-white' : 'text-amber-400' %>"><i data-lucide="user-cog" class="w-6 h-6"></i></a>
        <a href="/logs" class="p-2 flex-shrink-0 rounded-lg <%= title === 'Registro de Actividad' ? 'bg-indigo-600 text-white' : 'text-amber-400' %>"><i data-lucide="activity" class="w-6 h-6"></i></a>
        <% } %>
    </nav>

    <script>
        function initGlobalDarkMode() {
            // Ya aplicamos la clase en el <head>, pero sincronizamos los íconos
            const isDark = document.documentElement.classList.contains('dark');
            updateGlobalDarkModeUI(isDark);
        }

        function toggleGlobalDarkMode() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('darkMode', isDark);
            updateGlobalDarkModeUI(isDark);
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        function updateGlobalDarkModeUI(isDark) {
            const deskIcon = document.getElementById('darkModeIconDesk');
            const mobIcon = document.getElementById('darkModeIconMob');
            if (deskIcon) deskIcon.setAttribute('data-lucide', isDark ? 'sun' : 'moon');
            if (mobIcon) mobIcon.setAttribute('data-lucide', isDark ? 'sun' : 'moon');
        }

        document.addEventListener('DOMContentLoaded', initGlobalDarkMode);
        lucide.createIcons();
    </script>
</body>
</html>
