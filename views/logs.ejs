<div class="animate-in slide-in-from-bottom-4">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
        <h2 class="text-2xl font-bold text-slate-800 dark:text-white flex items-center gap-2 transition-colors">
            <i data-lucide="activity" class="text-amber-500"></i> Registro de Actividad (Audit Log)
        </h2>
        <button onclick="window.print()" class="w-full sm:w-auto px-4 py-2 bg-slate-800 dark:bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-slate-900 dark:hover:bg-indigo-700 shadow-md transition-all flex items-center justify-center gap-2 print:hidden">
            <i data-lucide="printer" class="w-4 h-4"></i> Imprimir Reporte
        </button>
    </div>

    <!-- Reglas de estilo robustas para impresión -->
    <style>
        @media print {
            body { background-color: white !important; color: black !important; }
            nav, header, button, .print\:hidden { display: none !important; }
            main { padding: 0 !important; margin: 0 !important; overflow: visible !important; }
            .bg-white, .dark\:bg-slate-800 { box-shadow: none !important; border: none !important; background: white !important; }
            .overflow-x-auto { overflow: visible !important; }
            table { width: 100% !important; border-collapse: collapse !important; }
            th, td { color: black !important; border-bottom: 1px solid #ddd !important; }
            tr { break-inside: avoid; page-break-inside: avoid; }
            h2, h3 { color: black !important; page-break-after: avoid; }
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        }
    </style>

    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 mb-8 transition-colors" style="page-break-inside: avoid;">
        <div class="p-4 sm:p-6 border-b border-slate-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50 flex justify-between items-center transition-colors">
            <h3 class="text-lg font-semibold text-slate-800 dark:text-white transition-colors">Últimos 500 movimientos en el sistema</h3>
        </div>
        
        <div class="overflow-x-auto w-full">
            <table class="w-full text-left border-collapse min-w-[800px]">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-900/50 text-slate-600 dark:text-slate-300 text-sm border-b border-slate-200 dark:border-slate-700 transition-colors">
                        <th class="p-4 font-semibold whitespace-nowrap">Fecha y Hora</th>
                        <th class="p-4 font-semibold whitespace-nowrap">Usuario</th>
                        <th class="p-4 font-semibold whitespace-nowrap">Acción</th>
                        <th class="p-4 font-semibold w-full">Detalles</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-700/50 text-sm transition-colors">
                    <% if (logs.length === 0) { %>
                        <tr>
                            <td colspan="4" class="p-8 text-center text-slate-500 dark:text-slate-400">No hay actividad registrada aún en el sistema.</td>
                        </tr>
                    <% } else { %>
                        <% logs.forEach(function(log) { %>
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                <!-- Formateamos la fecha -->
                                <td class="p-4 whitespace-nowrap text-slate-500 dark:text-slate-400 font-medium">
                                    <%= new Date(log.created_at).toLocaleString('es-CO') %>
                                </td>
                                
                                <td class="p-4 whitespace-nowrap">
                                    <span class="px-2 py-1 bg-indigo-50 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 rounded-md font-bold text-xs transition-colors"><i data-lucide="user" class="w-3 h-3 inline mr-1"></i><%= log.username %></span>
                                </td>
                                
                                <td class="p-4 whitespace-nowrap">
                                    <% 
                                        let badgeColor = 'bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300';
                                        if(log.action.includes('NUEVO') || log.action.includes('CREAR')) badgeColor = 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400';
                                        if(log.action.includes('ELIMIN')) badgeColor = 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400';
                                        if(log.action.includes('MODIFIC') || log.action.includes('EDITAR')) badgeColor = 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400';
                                        if(log.action.includes('CHECK_IN')) badgeColor = 'bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-400';
                                        if(log.action.includes('RESPALDO')) badgeColor = 'bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400';
                                    %>
                                    <span class="px-2 py-1 <%= badgeColor %> rounded-md font-semibold text-xs transition-colors"><%= log.action %></span>
                                </td>
                                
                                <td class="p-4 text-slate-700 dark:text-slate-300 leading-relaxed transition-colors">
                                    <%= log.details %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- SCRIPT PARA IMPRESIÓN LIMPIA EN MODO OSCURO -->
<script>
    window.addEventListener('beforeprint', () => {
        if (document.documentElement.classList.contains('dark')) {
            document.documentElement.classList.remove('dark');
            document.documentElement.setAttribute('data-print-dark', 'true');
        }
    });
    window.addEventListener('afterprint', () => {
        if (document.documentElement.getAttribute('data-print-dark') === 'true') {
            document.documentElement.classList.add('dark');
            document.documentElement.removeAttribute('data-print-dark');
        }
    });
</script>
