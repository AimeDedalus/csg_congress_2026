<div class="animate-in slide-in-from-bottom-4 relative">
    <h2 class="text-2xl font-bold text-slate-800 dark:text-white mb-6 flex items-center gap-2 transition-colors">
        <i data-lucide="user-cog" class="text-amber-500"></i> Gestión de Usuarios (Superadmin)
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- FORMULARIO NUEVO USUARIO -->
        <div class="lg:col-span-1">
            <div class="bg-white dark:bg-slate-800 p-6 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 transition-colors">
                <h3 class="text-lg font-semibold text-slate-800 dark:text-white mb-4 border-b border-slate-100 dark:border-slate-700 pb-2">Crear Nuevo Usuario</h3>
                <form action="/users/create" method="POST" class="space-y-4">
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Nombre de Usuario</label>
                        <input type="text" name="username" required placeholder="ej. taquilla1" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-amber-500 outline-none transition-colors">
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Contraseña</label>
                        <input type="password" name="password" required placeholder="••••••••" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-amber-500 outline-none transition-colors">
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Permisos (Rol)</label>
                        <select name="role" required class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-white focus:ring-2 focus:ring-amber-500 outline-none transition-colors">
                            <option value="regular">Staff Regular (Solo Entrada)</option>
                            <option value="admin">Administrador (Gestión Total)</option>
                            <option value="superadmin">Superadmin (Crear Usuarios)</option>
                        </select>
                    </div>
                    <button type="submit" class="w-full py-2.5 bg-amber-500 text-white rounded-lg font-semibold hover:bg-amber-600 shadow-md transition-all flex items-center justify-center gap-2 mt-2">
                        <i data-lucide="plus-circle" class="w-5 h-5"></i> Crear Usuario
                    </button>
                </form>
            </div>
        </div>

        <!-- LISTA DE USUARIOS -->
        <div class="lg:col-span-2">
            <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden h-full transition-colors">
                <div class="p-4 sm:p-6 border-b border-slate-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50 transition-colors">
                    <h3 class="text-lg font-semibold text-slate-800 dark:text-white">Usuarios Activos en el Sistema</h3>
                </div>
                <div class="overflow-x-auto w-full">
                    <table class="w-full text-left border-collapse min-w-[600px]">
                        <thead>
                            <tr class="bg-slate-50 dark:bg-slate-900/50 text-slate-600 dark:text-slate-300 text-sm border-b border-slate-200 dark:border-slate-700 transition-colors">
                                <th class="p-4 font-semibold whitespace-nowrap">ID</th>
                                <th class="p-4 font-semibold whitespace-nowrap">Usuario</th>
                                <th class="p-4 font-semibold whitespace-nowrap">Permisos</th>
                                <th class="p-4 font-semibold text-right whitespace-nowrap">Acción</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-700/50">
                            <% users.forEach(function(u) { %>
                                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                    <td class="p-4 font-medium text-slate-500 dark:text-slate-400">#<%= u.id %></td>
                                    <td class="p-4 font-bold text-slate-800 dark:text-slate-200">
                                        <%= u.username %>
                                        <% if (user.id === u.id) { %>
                                            <span class="ml-2 text-xs bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400 px-2 py-0.5 rounded-full transition-colors">Tú</span>
                                        <% } %>
                                    </td>
                                    <td class="p-4">
                                        <span class="px-3 py-1.5 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded-md text-sm font-semibold capitalize transition-colors"><%= u.role %></span>
                                    </td>
                                    <td class="p-4 text-right flex justify-end gap-2 items-center">
                                        <% if (user.id !== u.id || u.role === 'superadmin') { %>
                                            <button type="button" onclick="openEditModal('<%= u.id %>', '<%= u.username %>', '<%= u.role %>')" class="p-2 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 rounded-lg transition-colors" title="Editar Usuario">
                                                <i data-lucide="edit" class="w-5 h-5"></i>
                                            </button>
                                        <% } %>
                                        <% if (user.id !== u.id) { %>
                                            <form action="/users/delete" method="POST" class="inline m-0" onsubmit="return confirm('¿Seguro que deseas eliminar a <%= u.username %>? No podrá acceder al sistema.');">
                                                <input type="hidden" name="id" value="<%= u.id %>">
                                                <button type="submit" class="p-2 text-red-500 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-lg transition-colors" title="Eliminar Usuario">
                                                    <i data-lucide="trash-2" class="w-5 h-5"></i>
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <button disabled class="p-2 text-slate-300 dark:text-slate-600 cursor-not-allowed transition-colors"><i data-lucide="trash-2" class="w-5 h-5"></i></button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- SECCIÓN DE RESPALDOS -->
        <div class="lg:col-span-3 mt-4">
            <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 overflow-hidden transition-colors">
                <div class="p-4 sm:p-6 border-b border-slate-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-900/50 flex justify-between items-center transition-colors">
                    <h3 class="text-lg font-semibold text-slate-800 dark:text-white flex items-center gap-2">
                        <i data-lucide="database" class="w-5 h-5 text-indigo-600 dark:text-indigo-400"></i> Respaldo y Restauración de Datos
                    </h3>
                </div>
                <div class="p-4 sm:p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="p-6 border border-indigo-100 dark:border-indigo-900/30 bg-indigo-50/50 dark:bg-indigo-900/10 rounded-xl text-center transition-colors">
                        <i data-lucide="download-cloud" class="w-12 h-12 text-indigo-500 dark:text-indigo-400 mx-auto mb-4"></i>
                        <h4 class="text-lg font-bold text-slate-800 dark:text-white mb-2 transition-colors">Exportar Base de Datos</h4>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-6 px-4 transition-colors">Descarga un archivo seguro con todos los registros de los asistentes actuales.</p>
                        <a href="/users/backup" class="inline-flex items-center justify-center gap-2 w-full sm:w-auto px-6 py-3 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 shadow-md transition-all">
                            Descargar Respaldo JSON
                        </a>
                    </div>
                    <div class="p-6 border border-amber-100 dark:border-amber-900/30 bg-amber-50/50 dark:bg-amber-900/10 rounded-xl text-center transition-colors">
                        <i data-lucide="upload-cloud" class="w-12 h-12 text-amber-500 dark:text-amber-400 mx-auto mb-4"></i>
                        <h4 class="text-lg font-bold text-slate-800 dark:text-white mb-2 transition-colors">Restaurar Base de Datos</h4>
                        <p class="text-sm text-slate-500 dark:text-slate-400 mb-6 px-4 transition-colors">Sube un archivo de respaldo. <strong class="text-red-500 dark:text-red-400 font-semibold">Atención: Esto borrará los datos actuales.</strong></p>
                        <input type="file" id="restoreFile" accept=".json" class="hidden" onchange="handleRestore(this)">
                        <button type="button" onclick="document.getElementById('restoreFile').click()" class="inline-flex items-center justify-center gap-2 w-full sm:w-auto px-6 py-3 bg-amber-500 text-white rounded-lg font-medium hover:bg-amber-600 shadow-md transition-all">
                            Subir Archivo JSON
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============================================== -->
<!-- MODAL FLOTANTE DE EDICIÓN DE USUARIOS          -->
<!-- ============================================== -->
<div id="editUserModal" class="hidden fixed inset-0 bg-slate-900/50 dark:bg-slate-950/80 backdrop-blur-sm z-[150] flex items-center justify-center p-4 animate-in fade-in transition-colors">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-xl w-full max-w-md overflow-hidden animate-in zoom-in duration-200 transition-colors border border-slate-200 dark:border-slate-700">
        
        <div class="p-6 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center bg-slate-50 dark:bg-slate-900/50 transition-colors">
            <h3 class="text-xl font-bold text-slate-800 dark:text-white flex items-center gap-2">
                <i data-lucide="user-cog" class="text-indigo-600 dark:text-indigo-400 w-6 h-6"></i> Editar Usuario
            </h3>
            <button type="button" onclick="closeEditModal()" class="text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">
                <svg xmlns="[http://www.w3.org/2000/svg](http://www.w3.org/2000/svg)" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        
        <form action="/users/update" method="POST" class="p-6 space-y-5">
            <input type="hidden" name="id" id="editUserId">
            
            <div class="flex flex-col gap-1.5">
                <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Nombre de Usuario</label>
                <input type="text" name="username" id="editUserName" required class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-white focus:ring-2 focus:ring-indigo-500 outline-none transition-colors">
            </div>
            
            <div class="flex flex-col gap-1.5">
                <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Nueva Contraseña</label>
                <input type="password" name="password" placeholder="(Dejar en blanco para no cambiarla)" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-slate-50 dark:bg-slate-900/50 text-slate-800 dark:text-white focus:bg-white dark:focus:bg-slate-700 placeholder-slate-400 focus:ring-2 focus:ring-indigo-500 outline-none transition-colors">
                <span class="text-xs text-slate-400 dark:text-slate-500">Si no escribes nada, se mantendrá la contraseña actual.</span>
            </div>
            
            <div class="flex flex-col gap-1.5">
                <label class="text-sm font-semibold text-slate-700 dark:text-slate-300">Permisos (Rol)</label>
                <select name="role" id="editUserRole" required class="w-full px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-800 dark:text-white focus:ring-2 focus:ring-indigo-500 outline-none transition-colors">
                    <option value="regular">Staff Regular (Solo Entrada)</option>
                    <option value="admin">Administrador (Gestión Total)</option>
                    <option value="superadmin">Superadmin (Crear Usuarios)</option>
                </select>
            </div>

            <div class="pt-4 flex gap-3 justify-end border-t border-slate-100 dark:border-slate-700 mt-2 transition-colors">
                <button type="button" onclick="closeEditModal()" class="w-full sm:w-auto px-5 py-2.5 bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg font-semibold hover:bg-slate-200 dark:hover:bg-slate-600 transition-colors">Cancelar</button>
                <button type="submit" class="w-full sm:w-auto px-5 py-2.5 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700 shadow-md transition-all">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditModal(id, username, role) {
        document.getElementById('editUserId').value = id;
        document.getElementById('editUserName').value = username;
        document.getElementById('editUserRole').value = role;
        document.querySelector('input[name="password"]').value = '';
        document.getElementById('editUserModal').classList.remove('hidden');
    }

    function closeEditModal() {
        document.getElementById('editUserModal').classList.add('hidden');
    }

    async function handleRestore(input) {
        const file = input.files[0];
        if (!file) return;

        if (!confirm('ATENCIÓN: Restaurar un respaldo eliminará todos los asistentes registrados actualmente y los reemplazará permanentemente. ¿Deseas continuar bajo tu propio riesgo?')) {
            input.value = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = async (e) => {
            try {
                const data = JSON.parse(e.target.result);
                alert('Cargando respaldo al servidor... Por favor espera.');
                
                const res = await fetch('/users/restore', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                const result = await res.json();
                if (result.success) {
                    alert('¡Respaldo restaurado exitosamente! La página se recargará.');
                    window.location.reload();
                } else {
                    alert('Error al restaurar: ' + result.error);
                }
            } catch (err) {
                alert('El archivo seleccionado no tiene el formato de respaldo correcto o está corrupto.');
            }
            input.value = '';
        };
        reader.readAsText(file);
    }
</script>
