<div class="animate-in fade-in">
    <!-- ZONA FIJA (STICKY) PARA EL TÍTULO, BOTÓN Y FILTRO -->
    <div class="sticky top-0 z-30 bg-slate-50 dark:bg-slate-900 pt-4 pb-4 mb-6 border-b border-slate-200 dark:border-slate-700 shadow-sm -mt-4 -mx-4 px-4 sm:-mx-6 sm:px-6 md:-mx-10 md:px-10 transition-colors print:static print:shadow-none print:border-none print:p-0 print:m-0 print:bg-transparent">
        
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
            <h2 class="text-2xl font-bold text-slate-800 dark:text-white flex items-center gap-2 transition-colors">
                <i data-lucide="file-text" class="text-indigo-600 dark:text-indigo-400"></i> Reportes Generales
            </h2>
            <button onclick="window.print()" class="w-full sm:w-auto px-4 py-2 bg-slate-800 dark:bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-slate-900 dark:hover:bg-indigo-700 shadow-md transition-all flex items-center justify-center gap-2 print:hidden">
                <i data-lucide="printer" class="w-4 h-4"></i> Imprimir / Guardar PDF
            </button>
        </div>

        <!-- Menú de Filtro -->
        <div class="bg-white dark:bg-slate-800 p-4 sm:p-5 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 print:hidden transition-colors">
            <form action="/reports" method="GET" class="flex flex-col sm:flex-row gap-4 items-center">
                <input type="hidden" name="sort" value="<%= typeof sortOrder !== 'undefined' ? sortOrder : 'asc' %>">
                <label class="font-semibold text-slate-700 dark:text-slate-200 whitespace-nowrap">Filtrar Reporte:</label>
                <select name="filter" class="w-full sm:w-auto flex-1 px-4 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 focus:ring-2 focus:ring-indigo-500 outline-none bg-slate-50 dark:bg-slate-700 text-slate-800 dark:text-white cursor-pointer transition-colors" onchange="this.form.submit()">
                    <optgroup label="Agrupaciones Generales">
                        <option value="all" <%= typeof filter !== 'undefined' && filter === 'all' ? 'selected' : '' %>>Todos los Roles</option>
                        <option value="iglesia" <%= typeof filter !== 'undefined' && filter === 'iglesia' ? 'selected' : '' %>>Agrupado por Iglesias</option>
                    </optgroup>
                    <optgroup label="Por Asistencia">
                        <option value="presentes" <%= typeof filter !== 'undefined' && filter === 'presentes' ? 'selected' : '' %>>Solo Presentes (Adentro)</option>
                        <option value="ausentes" <%= typeof filter !== 'undefined' && filter === 'ausentes' ? 'selected' : '' %>>Solo Ausentes (Pendientes)</option>
                    </optgroup>
                    <optgroup label="Por Sexo">
                        <option value="masculino" <%= typeof filter !== 'undefined' && filter === 'masculino' ? 'selected' : '' %>>Solo Hombres</option>
                        <option value="femenino" <%= typeof filter !== 'undefined' && filter === 'femenino' ? 'selected' : '' %>>Solo Mujeres</option>
                    </optgroup>
                    <optgroup label="Por Rol Específico">
                        <option value="pastor" <%= typeof filter !== 'undefined' && filter === 'pastor' ? 'selected' : '' %>>Solo Pastores</option>
                        <option value="leader" <%= typeof filter !== 'undefined' && filter === 'leader' ? 'selected' : '' %>>Solo Líderes</option>
                        <option value="cordinador" <%= typeof filter !== 'undefined' && filter === 'cordinador' ? 'selected' : '' %>>Solo Coordinadores</option>
                        <option value="voluntario" <%= typeof filter !== 'undefined' && filter === 'voluntario' ? 'selected' : '' %>>Solo Voluntarios</option>
                        <option value="public" <%= typeof filter !== 'undefined' && filter === 'public' ? 'selected' : '' %>>Solo Público General</option>
                    </optgroup>
                </select>
            </form>
        </div>
    </div>

    <!-- Reglas de estilo robustas para impresión -->
    <style>
        @media print {
            body { background-color: white !important; color: black !important; }
            nav, header, button, .print\:hidden { display: none !important; }
            main { padding: 0 !important; margin: 0 !important; overflow: visible !important; }
            .bg-white, .dark\:bg-slate-800 { box-shadow: none !important; border: none !important; background: white !important; }
            .overflow-auto { overflow: visible !important; max-h: none !important; }
            table { width: 100% !important; border-collapse: collapse !important; }
            th, td { color: black !important; border-bottom: 1px solid #ddd !important; }
            tr { break-inside: avoid; page-break-inside: avoid; }
            h2, h3 { color: black !important; page-break-after: avoid; }
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        }
    </style>

    <% const nextSort = (typeof sortOrder !== 'undefined' && sortOrder === 'asc') ? 'desc' : 'asc'; %>
    <% const currentFilter = typeof filter !== 'undefined' ? filter : 'all'; %>

    <!-- ==== MACRO PARA RENDERIZAR TABLAS ==== -->
    <% 
        const renderTable = (title, iconClass, colorClass, dataArray) => { 
    %>
    <div class="bg-white dark:bg-slate-800 p-5 sm:p-6 rounded-xl shadow-sm border border-slate-200 dark:border-slate-700 mb-8 transition-colors" style="page-break-inside: avoid;">
        <h3 class="text-lg font-semibold text-slate-800 dark:text-white mb-4 border-b border-slate-200 dark:border-slate-700 pb-2 flex items-center gap-2">
            <i data-lucide="<%= iconClass %>" class="w-5 h-5 <%= colorClass %>"></i> <%= title %> (<%= dataArray ? dataArray.length : 0 %>)
        </h3>
        <!-- CAMBIAMOS EL DIV POR UNO CON MAX-H PARA CREAR EL SCROLL INTERNO -->
        <div class="overflow-auto w-full max-h-[65vh] relative">
            <table class="w-full text-left border-collapse min-w-[600px] relative">
                <!-- AÑADIMOS STICKY A LA CABECERA Y COLOR SÓLIDO AL TR -->
                <thead class="sticky top-0 z-20 shadow-sm">
                    <tr class="bg-slate-100 dark:bg-slate-900 text-slate-600 dark:text-slate-300 text-sm border-b border-slate-200 dark:border-slate-700 transition-colors">
                        <th class="p-3 font-semibold whitespace-nowrap">Ticket y Doc</th>
                        <th class="p-3 font-semibold whitespace-nowrap">Nombres</th>
                        <th class="p-3 font-semibold whitespace-nowrap">
                            <a href="/reports?filter=<%= currentFilter %>&sort=<%= nextSort %>" class="inline-flex items-center gap-1.5 px-3 py-1.5 -ml-3 rounded-md hover:bg-indigo-50 dark:hover:bg-indigo-900/30 text-indigo-700 dark:text-indigo-400 transition-colors border border-transparent hover:border-indigo-100 dark:hover:border-indigo-800">
                                Apellidos
                                <% if (typeof sortOrder !== 'undefined' && sortOrder === 'asc') { %><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600 dark:text-indigo-400"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg><% } else { %><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-600 dark:text-indigo-400"><path d="m5 12 7-7 7 7"/><path d="M12 19V5"/></svg><% } %>
                            </a>
                        </th>
                        <th class="p-3 font-semibold whitespace-nowrap">Iglesia / Rol</th>
                        <th class="p-3 font-semibold whitespace-nowrap">Teléfono</th>
                        <th class="p-3 font-semibold whitespace-nowrap">Estado y Hora</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-700/50 text-sm transition-colors">
                    <% if (!dataArray || dataArray.length === 0) { %>
                        <tr><td colspan="6" class="p-4 text-center text-slate-500 dark:text-slate-400">No hay registros para mostrar.</td></tr>
                    <% } else { %>
                        <% dataArray.forEach(function(a) { %>
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                                <td class="p-3"><strong class="text-indigo-600 dark:text-indigo-400 block"><%= a.ticket %></strong><span class="text-xs text-slate-500 dark:text-slate-400"><%= a.id_doc_type %>: <%= a.id_doc %></span></td>
                                <td class="p-3 font-medium text-slate-800 dark:text-slate-200"><%= a.first_name %></td>
                                <td class="p-3 font-medium text-slate-800 dark:text-slate-200"><%= a.last_name %></td>
                                <td class="p-3">
                                    <div class="text-slate-800 dark:text-slate-200 font-medium mb-1"><%= a.church || 'Sin Iglesia' %></div>
                                    <% 
                                        let roleClass = 'bg-slate-100 dark:bg-slate-700 text-slate-800 dark:text-slate-200 border-slate-200 dark:border-slate-600';
                                        let roleName = a.role;
                                        if (a.role === 'Pastor') { roleClass = 'bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300 border-blue-200 dark:border-blue-800'; }
                                        else if (a.role === 'Leader') { roleClass = 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-800 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800'; roleName = 'Líder'; }
                                        else if (a.role === 'Cordinador') { roleClass = 'bg-purple-100 dark:bg-purple-900/40 text-purple-800 dark:text-purple-300 border-purple-200 dark:border-purple-800'; roleName = 'Coordinador'; }
                                        else if (a.role === 'Voluntario') { roleClass = 'bg-pink-100 dark:bg-pink-900/40 text-pink-800 dark:text-pink-300 border-pink-200 dark:border-pink-800'; }
                                        else if (a.role === 'Public') { roleClass = 'bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-300 border-amber-200 dark:border-amber-800'; roleName = 'Público'; }
                                    %>
                                    <span class="px-2 py-0.5 rounded-full border text-[10px] font-bold tracking-wider uppercase shadow-sm transition-colors <%= roleClass %>">
                                        <%= roleName %>
                                    </span>
                                </td>
                                <td class="p-3 text-slate-700 dark:text-slate-300"><%= a.phone %></td>
                                <td class="p-3 text-slate-700 dark:text-slate-300">
                                    <% if (a.is_present) { %>
                                        <div class="flex flex-col items-start gap-1">
                                            <span class="inline-flex items-center gap-1 text-emerald-600 dark:text-emerald-400 text-sm font-semibold bg-emerald-50 dark:bg-emerald-900/30 px-2 py-1 rounded-full"><i data-lucide="check-circle" class="w-4 h-4"></i> Adentro</span>
                                            <% if (a.check_in_time) { %>
                                                <span class="text-[11px] text-slate-500 dark:text-slate-400 font-medium ml-1"><i data-lucide="clock" class="w-3 h-3 inline mr-0.5"></i><%= new Date(a.check_in_time).toLocaleString('es-CO', { day: '2-digit', month: 'short', hour: '2-digit', minute:'2-digit' }) %></span>
                                            <% } %>
                                        </div>
                                    <% } else { %>
                                        <span class="inline-flex items-center gap-1 text-amber-600 dark:text-amber-400 text-sm font-semibold bg-amber-50 dark:bg-amber-900/30 px-2 py-1 rounded-full"><i data-lucide="x-circle" class="w-4 h-4"></i> Pendiente</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    <% } %>

    <!-- RENDERIZADO CONDICIONAL DE TODAS LAS TABLAS -->
    <% if ((currentFilter === 'all' || currentFilter === 'pastor') && typeof pastors !== 'undefined') { renderTable('Pastores', 'users', 'text-blue-500 dark:text-blue-400', pastors); } %>
    <% if ((currentFilter === 'all' || currentFilter === 'leader') && typeof leaders !== 'undefined') { renderTable('Líderes', 'users', 'text-emerald-500 dark:text-emerald-400', leaders); } %>
    <% if ((currentFilter === 'all' || currentFilter === 'cordinador') && typeof coordinators !== 'undefined') { renderTable('Coordinadores', 'users', 'text-purple-500 dark:text-purple-400', coordinators); } %>
    <% if ((currentFilter === 'all' || currentFilter === 'voluntario') && typeof volunteers !== 'undefined') { renderTable('Voluntarios', 'users', 'text-pink-500 dark:text-pink-400', volunteers); } %>
    <% if ((currentFilter === 'all' || currentFilter === 'public') && typeof publicAttendees !== 'undefined') { renderTable('Público General', 'users', 'text-amber-500 dark:text-amber-400', publicAttendees); } %>

    <% if (currentFilter === 'presentes') { renderTable('Presentes (Ya Ingresaron)', 'check-circle', 'text-emerald-600 dark:text-emerald-400', typeof present !== 'undefined' ? present : []); } %>
    <% if (currentFilter === 'ausentes') { renderTable('Ausentes (No Han Llegado)', 'x-circle', 'text-amber-600 dark:text-amber-400', typeof absent !== 'undefined' ? absent : []); } %>

    <% if (currentFilter === 'masculino') { renderTable('Hombres', 'user', 'text-blue-600 dark:text-blue-400', typeof men !== 'undefined' ? men : []); } %>
    <% if (currentFilter === 'femenino') { renderTable('Mujeres', 'user', 'text-pink-600 dark:text-pink-400', typeof women !== 'undefined' ? women : []); } %>

    <% if (currentFilter === 'iglesia') { %>
        <% 
            const safeChurchGroups = typeof churchGroups !== 'undefined' ? churchGroups : {};
            const sortedChurches = Object.keys(safeChurchGroups).sort();
            sortedChurches.forEach(churchName => {
                renderTable(churchName, 'home', 'text-indigo-600 dark:text-indigo-400', safeChurchGroups[churchName]);
            });
        %>
    <% } %>

    <!-- SCRIPT PARA IMPRESIÓN LIMPIA EN MODO OSCURO -->
    <script>
        window.addEventListener('beforeprint', () => {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                document.documentElement.setAttribute('data-print-dark', 'true');
            }
        });
        window.addEventListener('afterprint', () => {
            if (document.documentElement.getAttribute('data-print-dark') === 'true') {
                document.documentElement.classList.add('dark');
                document.documentElement.removeAttribute('data-print-dark');
            }
        });
    </script>
</div>
